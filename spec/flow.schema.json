{
  "$comment": "Flow Engine 플로우 정의 계약 (골든 스키마 — bats와 pytest 양쪽이 이 파일로 검증). lib/flow.sh와 gateway가 동일 스키마로 읽고 써야 한다. 설계 노트: deps[]가 곧 병렬 그룹을 암시(같은 deps 셋 = 병렬 실행 가능). jq 미사용 파서(grep/sed)를 위해 steps 배열을 1depth로 유지하고 중첩 객체를 최소화한다.",
  "required": [
    "flow_id",
    "goal",
    "created",
    "status",
    "steps"
  ],
  "types": {
    "flow_id": "string(uuid)",
    "goal": "string",
    "created": "string(iso8601)",
    "status": "string(pending|running|paused|completed|failed)",
    "steps": "array(step)"
  },
  "step_required": [
    "id",
    "soul",
    "task",
    "deps",
    "retry",
    "approval",
    "on_fail",
    "status"
  ],
  "step_types": {
    "id": "string",
    "soul": "string(soul_name|empty=host)",
    "task": "string",
    "deps": "array(string)",
    "retry": "integer(0-3,default=1)",
    "approval": "boolean",
    "on_fail": "string(abort|continue|goto:<step_id>)",
    "status": "string(pending|waiting_approval|approved|running|done|failed|skipped)"
  }
}
